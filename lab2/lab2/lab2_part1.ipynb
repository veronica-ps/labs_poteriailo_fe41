def update_indexes(data):
    data['Area_ID'] = data['Area_ID'].map(index_dict)
    data['Area_Name'] = data['Area_ID'].map(names_dict)
    return data[['Year', 'Week', 'Area_ID', 'Area_Name', 'SMN', 'SMT', 'VCI', 'TCI', 'VHI']]

